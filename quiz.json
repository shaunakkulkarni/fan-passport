{
  "version": 2,
  "questions": [
    {
      "id": "q1",
      "prompt": "How do you want your club to win?",
      "subtext": "Pick the version of football that gets you off the couch.",
      "type": "standard",
      "options": [
        {
          "label": "Total control",
          "description": "Death by a thousand passes — starve the opponent of the ball until they break.",
          "tags": { "possession": 2, "technical": 2, "patience": 1 }
        },
        {
          "label": "The knockout blow",
          "description": "Sit deep, absorb pressure, then hit them on the break before they know what happened.",
          "tags": { "counterattack": 2, "physical": 1, "patience": 1 }
        },
        {
          "label": "Organized chaos",
          "description": "End-to-end, high-event, nobody's defense is safe. Entertainment over control.",
          "tags": { "highpress": 3, "physical": 1 }
        },
        {
          "label": "Grind it out",
          "description": "Set pieces, duels, a back line that doesn't blink. Ugly wins still count.",
          "tags": { "physical": 2, "setpieces": 2, "patience": 1 }
        }
      ]
    },
    {
      "id": "q2",
      "prompt": "When you picture yourself at a match, what's the scene?",
      "subtext": "There's no wrong answer — just the version of fandom that feels like yours.",
      "type": "standard",
      "options": [
        {
          "label": "The wall of noise",
          "description": "Thousands standing, singing for 90 minutes straight. The stadium IS the experience. You don't sit, you don't stop.",
          "tags": { "fan-culture": "ultras", "ultras": 2, "bloodfeud": 1 }
        },
        {
          "label": "The family outing",
          "description": "Good view, clean concourse, kids running around. Football as a Saturday event, not a religious experience.",
          "tags": { "fan-culture": "family", "community": 1, "accessible": 1 }
        },
        {
          "label": "The intellectual",
          "description": "You're there for the tactical chess match. You want to analyze formations, debate substitutions, appreciate the system.",
          "tags": { "fan-culture": "intellectual", "technical": 2, "possession": 1 }
        },
        {
          "label": "The rebels",
          "description": "The fans who march, protest, fight ownership. Football is political, and your club takes a side.",
          "tags": { "fan-culture": "rebel", "rebellious": 2, "community": 1 }
        }
      ]
    },
    {
      "id": "q3",
      "prompt": "What kind of story do you want to be part of?",
      "subtext": "Every club has a narrative. Which one is yours?",
      "type": "standard",
      "options": [
        {
          "label": "The underdog rising",
          "description": "A club that punches above its weight, shocks the giants, makes you believe in miracles. Think Leicester 2016.",
          "tags": { "narrative": "underdog", "underdog": 2, "journey": 1 }
        },
        {
          "label": "The dynasty",
          "description": "A club that expects to win. Every year. The pressure is the point — anything less than a trophy is failure.",
          "tags": { "narrative": "dynasty", "trophyhunger": 2, "galactico": 1 }
        },
        {
          "label": "The cursed romantic",
          "description": "Long-suffering, loyal through decades of heartbreak. The pain IS the identity. One day it'll be worth it.",
          "tags": { "narrative": "cursed", "journey": 2, "ultras": 1 }
        },
        {
          "label": "The project",
          "description": "A club building something new — smart recruitment, young talent, a vision taking shape. You want to watch the ascent.",
          "tags": { "narrative": "project", "academy": 2, "journey": 1 }
        }
      ]
    },
    {
      "id": "q4",
      "prompt": "How do you want your club to handle rivalries?",
      "subtext": "Some rivalries are family feuds. Some are blood feuds.",
      "type": "standard",
      "options": [
        {
          "label": "Toxic and beautiful",
          "description": "The derby is everything. You hate the rival more than you love your own team. Losing to them is unthinkable.",
          "tags": { "bloodfeud": 3, "ultras": 1 }
        },
        {
          "label": "Respectful but real",
          "description": "There's history, there's tension, but it stays on the pitch. You want edge, not venom.",
          "tags": { "friendlyrivalry": 2, "journey": 1 }
        },
        {
          "label": "I don't care about rivalries",
          "description": "I'm here for the football, not the grudges. Rivalry culture is fine but it's not my identity.",
          "tags": { "rivalryagnostic": 2, "journey": 1 }
        },
        {
          "label": "The enemy of my enemy",
          "description": "I want a club whose rivals are clubs I already dislike by reputation. Give me a side with enemies worth having.",
          "tags": { "bloodfeud": 1, "journey": 1, "underdog": 1 }
        }
      ]
    },
    {
      "id": "q5",
      "prompt": "What's your tolerance for institutional drama?",
      "subtext": "Some clubs are rock-solid institutions. Others are a beautiful mess.",
      "type": "standard",
      "options": [
        {
          "label": "Rock solid",
          "description": "I want stability — long-term vision, a sporting director with a plan, no annual crisis. Boring excellence is fine by me.",
          "tags": { "stability": "stable", "patience": 2 }
        },
        {
          "label": "Beautiful chaos",
          "description": "I can handle the drama — manager changes, owner scandals, transfer sagas. The chaos is part of the charm.",
          "tags": { "stability": "chaotic", "highpress": 1 }
        },
        {
          "label": "Rebuild in progress",
          "description": "I want a club that's actively fixing something. New ownership, new philosophy, a turnaround story.",
          "tags": { "stability": "rebuilding", "journey": 2, "underdog": 1 }
        },
        {
          "label": "Win now, figure it out later",
          "description": "I don't care about the next five years. I want trophies THIS year. Spend money, hire the best, deal with consequences later.",
          "tags": { "stability": "win-now", "trophyhunger": 2, "galactico": 1 }
        }
      ]
    },
    {
      "id": "q6",
      "prompt": "What matters more — the trophy cabinet or the soul of the club?",
      "subtext": "Every club makes this trade-off. Where do you fall?",
      "type": "standard",
      "options": [
        {
          "label": "Trophies. Period.",
          "description": "I want a club that wins. If they're not competing for titles, what's the point? Legacy is measured in silverware.",
          "tags": { "ambition": "trophy-driven", "trophyhunger": 2, "galactico": 1, "aristocratic": 1 }
        },
        {
          "label": "Identity first",
          "description": "I want a club with a soul — a philosophy, a culture, something that makes them unique regardless of results. Winning is secondary to being authentic.",
          "tags": { "ambition": "identity-driven", "rebellious": 1, "community": 2 }
        },
        {
          "label": "The smart overachiever",
          "description": "I want a club that does more with less — data-driven recruitment, smart scouting, finding hidden gems. Winning through intelligence, not budget.",
          "tags": { "ambition": "smart-overachiever", "academy": 2, "underdog": 1 }
        },
        {
          "label": "The romantic choice",
          "description": "I want a club that feels like a story worth telling. History, passion, a connection to a place and people. Results come and go; the romance is permanent.",
          "tags": { "ambition": "romantic", "journey": 2, "ultras": 1, "diaspora": 1 }
        }
      ]
    },
